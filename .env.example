# ---------------------------------------------------------------------------
# Showcase overrides
# ---------------------------------------------------------------------------
# All variables are optional. Each one falls back to the built-in default
# (the same values the showcase ships with) when left unset, so this file
# is purely a reference of what can be customised.
#
# These are NEXT_PUBLIC_* vars — Next.js inlines them at build time, so
# rebuild after changing any of them. Copy this file to `.env.local` to
# override locally.

# --- Brand ---------------------------------------------------------------
NEXT_PUBLIC_BRAND_SHORT="KUI-react"
NEXT_PUBLIC_BRAND_NAME="KUIreact"
NEXT_PUBLIC_BRAND_INITIAL="K"
NEXT_PUBLIC_BRAND_TAGLINE="Composable UI System for Real Products"
NEXT_PUBLIC_BRAND_DESCRIPTION="KUIreact is a production-ready UI system built with Next.js. A composable design system and storefront-ready component architecture for real-world applications."

# --- Links ---------------------------------------------------------------
NEXT_PUBLIC_SITE_URL="https://next-js-components.kuray.dev"
NEXT_PUBLIC_GITHUB_URL="https://github.com/kuraykaraaslan/next_js_components"
NEXT_PUBLIC_AUTHOR_NAME="Kuray Karaaslan"
NEXT_PUBLIC_AUTHOR_URL="https://kuray.dev"

# --- Colors (light mode) -------------------------------------------------
# Any value left unset keeps the default from app/globals.css. Values are
# injected as CSS variables on :root after globals.css, so they override
# the defaults without editing CSS.
# NEXT_PUBLIC_COLOR_PRIMARY="#3b82f6"
# NEXT_PUBLIC_COLOR_PRIMARY_HOVER="#2563eb"
# NEXT_PUBLIC_COLOR_PRIMARY_ACTIVE="#1d4ed8"
# NEXT_PUBLIC_COLOR_PRIMARY_SUBTLE="#eff6ff"
# NEXT_PUBLIC_COLOR_PRIMARY_FG="#ffffff"
# NEXT_PUBLIC_COLOR_SECONDARY="#8b5cf6"
# NEXT_PUBLIC_COLOR_SECONDARY_HOVER="#7c3aed"
# NEXT_PUBLIC_COLOR_SECONDARY_ACTIVE="#6d28d9"
# NEXT_PUBLIC_COLOR_SECONDARY_SUBTLE="#f5f3ff"
# NEXT_PUBLIC_COLOR_SECONDARY_FG="#ffffff"
# NEXT_PUBLIC_COLOR_SURFACE_BASE="#ffffff"
# NEXT_PUBLIC_COLOR_SURFACE_RAISED="#f9fafb"
# NEXT_PUBLIC_COLOR_SURFACE_OVERLAY="#f3f4f6"
# NEXT_PUBLIC_COLOR_SURFACE_SUNKEN="#e5e7eb"
# NEXT_PUBLIC_COLOR_BORDER="#e5e7eb"
# NEXT_PUBLIC_COLOR_BORDER_STRONG="#d1d5db"
# NEXT_PUBLIC_COLOR_BORDER_FOCUS="#3b82f6"

# --- Colors (dark mode) --------------------------------------------------
# Injected on .dark after globals.css.
# NEXT_PUBLIC_COLOR_PRIMARY_DARK="#60a5fa"
# NEXT_PUBLIC_COLOR_PRIMARY_HOVER_DARK="#93c5fd"
# NEXT_PUBLIC_COLOR_PRIMARY_ACTIVE_DARK="#1d4ed8"
# NEXT_PUBLIC_COLOR_PRIMARY_SUBTLE_DARK="#1e3a5f"
# NEXT_PUBLIC_COLOR_PRIMARY_FG_DARK="#ffffff"
# NEXT_PUBLIC_COLOR_SECONDARY_DARK="#a78bfa"
# NEXT_PUBLIC_COLOR_SECONDARY_HOVER_DARK="#c4b5fd"
# NEXT_PUBLIC_COLOR_SECONDARY_ACTIVE_DARK="#7c3aed"
# NEXT_PUBLIC_COLOR_SECONDARY_SUBTLE_DARK="#2e1065"
# NEXT_PUBLIC_COLOR_SECONDARY_FG_DARK="#ffffff"
# NEXT_PUBLIC_COLOR_SURFACE_BASE_DARK="#0f172a"
