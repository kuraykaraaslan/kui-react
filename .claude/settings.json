{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/auto-snapshot.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // \"\"' | grep -q '/modules/' && echo '{\"systemMessage\": \"Bu komponenti EJS projesine de eklemek ister misiniz?\"}' || true"
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(curl -s http://localhost:3000)",
      "Bash(grep -n \"// ─── \\\\|^  {$\\\\|^    {$\" /home/kuray/next_js_components/modules/showcase/data/showcase.data.tsx)",
      "Bash(echo \"EXIT:$?\")",
      "Bash(xargs ls *)"
    ],
    "additionalDirectories": [
      "/home/kuray/02_EJS_Components/src/types",
      "/home/kuray/02_EJS_Components/modules/ui",
      "/home/kuray/02_EJS_Components/src/data/sections",
      "/home/kuray/02_EJS_Components/src/data",
      "/home/kuray/02_EJS_Components/public/css",
      "/home/kuray/02_EJS_Components/views/showcase/partials",
      "/home/kuray/02_EJS_Components/modules/domain/common/auth",
      "/home/kuray/02_EJS_Components/modules/domain/common/user",
      "/home/kuray/02_EJS_Components/modules/domain/common/i18n",
      "/home/kuray/02_EJS_Components/modules/domain/common",
      "/home/kuray/02_EJS_Components/views/showcase"
    ]
  }
}
